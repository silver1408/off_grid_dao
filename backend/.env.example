# Backend Environment Variables
# Copy to backend/.env

# Blockchain RPC URL (Hardhat Node)
RPC_URL=http://127.0.0.1:8545

# Private key for deployment (optional - uses first account if not set)
# WARNING: Never commit real private keys!
# PRIVATE_KEY=0x...

# DAO Contract Address (auto-set after deploy)
# DAO_ADDRESS=0x...

# Contract Address (auto-set after deploy)
# CONTRACT_ADDRESS=0x...
