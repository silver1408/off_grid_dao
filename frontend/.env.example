# Frontend Environment Variables
# Copy to frontend/.env

# LOCAL DEVELOPMENT (on same machine)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# NETWORK ACCESS (replace with your IP)
# Find IP: ifconfig | grep "inet " | grep -v 127.0.0.1
# Example: 192.168.1.100
# VITE_API_BASE_URL=http://192.168.1.100:5000/api
# VITE_SOCKET_URL=http://192.168.1.100:5000

# PRODUCTION (for deployed backend)
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_SOCKET_URL=https://your-domain.com
